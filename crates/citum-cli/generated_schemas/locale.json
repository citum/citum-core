{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RawLocale",
  "description": "Raw locale format for YAML parsing. This is a simpler format that uses string keys for terms.",
  "type": "object",
  "required": [
    "locale"
  ],
  "properties": {
    "dates": {
      "description": "Date-related terms.",
      "default": {
        "am": null,
        "months": {
          "long": [],
          "short": []
        },
        "open-ended-term": null,
        "pm": null,
        "seasons": [],
        "timezone-utc": null,
        "uncertainty-term": null
      },
      "allOf": [
        {
          "$ref": "#/definitions/RawDateTerms"
        }
      ]
    },
    "locale": {
      "description": "The locale identifier (e.g., \"en-US\", \"de-DE\").",
      "type": "string"
    },
    "roles": {
      "description": "Role terms keyed by role name.",
      "default": {},
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/RawRoleTerm"
      }
    },
    "terms": {
      "description": "General terms keyed by term name.",
      "default": {},
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/RawTermValue"
      }
    },
    "locale-schema-version": {
      "description": "Schema version. Absent or \"1\" uses the legacy term-map path. \"2\" activates the new messages/dateFormats/grammarOptions path.",
      "type": [
        "string",
        "null"
      ]
    },
    "evaluation": {
      "description": "Runtime evaluation options (message syntax, evaluator hints).",
      "anyOf": [
        {
          "$ref": "#/definitions/EvaluationConfig"
        },
        {
          "type": "null"
        }
      ]
    },
    "messages": {
      "description": "ICU Message Format 1 messages keyed by message ID (v2 locales only).",
      "default": {},
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "date-formats": {
      "description": "Named date format presets: symbolic name \u2192 CLDR date pattern (v2 locales only).",
      "default": {},
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "number-formats": {
      "description": "Locale-level number formatting options.",
      "anyOf": [
        {
          "$ref": "#/definitions/NumberFormats"
        },
        {
          "type": "null"
        }
      ]
    },
    "grammar-options": {
      "description": "Grammar toggles that vary by language.",
      "anyOf": [
        {
          "$ref": "#/definitions/GrammarOptions"
        },
        {
          "type": "null"
        }
      ]
    },
    "legacy-term-aliases": {
      "description": "Backwards-compatibility aliases: old CSL term key \u2192 new message ID.",
      "default": {},
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "definitions": {
    "RawDateTerms": {
      "description": "Raw date terms for YAML parsing.",
      "type": "object",
      "properties": {
        "am": {
          "description": "Localized ante meridiem marker.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "months": {
          "description": "Localized month names.",
          "default": {
            "long": [],
            "short": []
          },
          "allOf": [
            {
              "$ref": "#/definitions/RawMonthNames"
            }
          ]
        },
        "open-ended-term": {
          "description": "Localized term for open-ended date ranges.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "pm": {
          "description": "Localized post meridiem marker.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "seasons": {
          "description": "Localized season names in display order.",
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "timezone-utc": {
          "description": "Localized label for UTC.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "uncertainty-term": {
          "description": "Localized term for uncertain dates.",
          "default": null,
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "RawMonthNames": {
      "description": "Raw month names for YAML parsing.",
      "type": "object",
      "properties": {
        "long": {
          "description": "Full month names.",
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "short": {
          "description": "Abbreviated month names.",
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "RawRoleTerm": {
      "description": "Raw role term with form-keyed values.",
      "type": "object",
      "properties": {
        "long": {
          "description": "Long-form role term.",
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/RawTermValue"
            },
            {
              "type": "null"
            }
          ]
        },
        "short": {
          "description": "Short-form role term.",
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/RawTermValue"
            },
            {
              "type": "null"
            }
          ]
        },
        "verb": {
          "description": "Verb-form role term.",
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/RawTermValue"
            },
            {
              "type": "null"
            }
          ]
        },
        "verb-short": {
          "description": "Short verb-form role term.",
          "default": null,
          "anyOf": [
            {
              "$ref": "#/definitions/RawTermValue"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "RawTermValue": {
      "description": "A term value that can be a simple string or have singular/plural forms.",
      "anyOf": [
        {
          "description": "Simple string value.",
          "type": "string"
        },
        {
          "description": "Form-keyed value (for terms with long/short forms).",
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/RawTermValue"
          }
        },
        {
          "description": "Singular/plural forms.",
          "type": "object",
          "required": [
            "plural",
            "singular"
          ],
          "properties": {
            "plural": {
              "description": "Plural form of the term.",
              "type": "string"
            },
            "singular": {
              "description": "Singular form of the term.",
              "type": "string"
            }
          }
        }
      ]
    },
    "EvaluationConfig": {
      "description": "Runtime evaluation options for a locale.",
      "type": "object",
      "properties": {
        "message-syntax": {
          "description": "Message syntax used in this locale's `messages` map.",
          "default": "static",
          "allOf": [
            {
              "$ref": "#/definitions/MessageSyntax"
            }
          ]
        }
      }
    },
    "GrammarOptions": {
      "description": "Grammar options that vary by language or regional convention.",
      "type": "object",
      "properties": {
        "punctuation-in-quote": {
          "description": "Whether to place periods/commas inside closing quotation marks (American style).",
          "default": false,
          "type": "boolean"
        },
        "nbsp-before-colon": {
          "description": "Whether to use a non-breaking space before colon/question mark (French style).",
          "default": false,
          "type": "boolean"
        },
        "open-quote": {
          "description": "Opening outer quotation mark character.",
          "default": "\u201c",
          "type": "string"
        },
        "close-quote": {
          "description": "Closing outer quotation mark character.",
          "default": "\u201d",
          "type": "string"
        },
        "open-inner-quote": {
          "description": "Opening inner (nested) quotation mark character.",
          "default": "\u2018",
          "type": "string"
        },
        "close-inner-quote": {
          "description": "Closing inner (nested) quotation mark character.",
          "default": "\u2019",
          "type": "string"
        },
        "serial-comma": {
          "description": "Whether to use a serial (Oxford) comma before the final list item.",
          "default": false,
          "type": "boolean"
        },
        "page-range-delimiter": {
          "description": "Delimiter between page range endpoints.",
          "default": "\u2013",
          "type": "string"
        }
      }
    },
    "MessageSyntax": {
      "description": "Message syntax variant active in a locale file.",
      "default": "static",
      "type": "string",
      "enum": [
        "static",
        "mf1",
        "mf2"
      ]
    },
    "NumberFormats": {
      "description": "Number formatting options for a locale.",
      "type": "object",
      "properties": {
        "decimal-separator": {
          "description": "Decimal separator (e.g., \".\" for en-US, \",\" for de-DE).",
          "default": ".",
          "type": "string"
        },
        "thousands-separator": {
          "description": "Thousands separator (e.g., \",\" for en-US, \".\" for de-DE).",
          "default": ",",
          "type": "string"
        },
        "minimum-digits": {
          "description": "Minimum digits to display.",
          "default": 1,
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        }
      }
    }
  }
}
