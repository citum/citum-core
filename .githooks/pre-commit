#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# 1. Bean hygiene check (same as CI and pre-push).
# Soft-stale matches are advisory by default; hard hygiene findings still fail.
BEAN_WRAPPER="$ROOT_DIR/.claude/skills/beans/bin/citum-bean"
if [[ -x "$BEAN_WRAPPER" ]]; then
  printf '[PRE-COMMIT] Running bean hygiene check...\n'
  if ! IGNORE_SOFT_STALE="${IGNORE_SOFT_STALE:-1}" "$BEAN_WRAPPER" hygiene; then
    printf '[ERROR] Bean hygiene failed. Fix before committing.\n' >&2
    exit 1
  fi
fi

# 2. Docs/Beans hygiene check (CI script)
if [[ -x "$ROOT_DIR/scripts/check-docs-beans-hygiene.sh" ]]; then
  printf '[PRE-COMMIT] Running docs and beans hygiene script...\n'
  if ! "$ROOT_DIR/scripts/check-docs-beans-hygiene.sh"; then
    printf '[ERROR] Docs/beans hygiene check failed. Fix before committing.\n' >&2
    exit 1
  fi
fi

# 3. Cargo fmt check (only if Rust files changed)
if git diff --cached --name-only | grep -qE '\.rs$|Cargo\.toml$|Cargo\.lock$'; then
  printf '[PRE-COMMIT] Running cargo fmt --check...\n'
  if ! cargo fmt --all -- --check; then
    printf '[ERROR] Code formatting check failed. Run `cargo fmt` and try again.\n' >&2
    exit 1
  fi
fi
