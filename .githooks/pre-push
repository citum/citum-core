#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$ROOT_DIR/scripts/pre-push-policy-base.sh"

# Check for Co-Authored-By commits in the push range
printf '[PRE-PUSH] Checking for Co-Authored-By commits...\n'
while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ -z "${local_ref:-}" || -z "${local_sha:-}" ]]; then
    continue
  fi

  if [[ "$local_sha" =~ ^0+$ ]]; then
    continue
  fi

  # Commits already accepted on origin/main are CI-governed history. When a
  # secondary mirror lags behind it, validate only the commits new to origin;
  # otherwise an old fixed history violation would block mirror catch-up.
  policy_base="$(pre_push_policy_base "$ROOT_DIR" "$local_sha" "$remote_sha")"

  # Check commit trailers for Co-Authored-By (match line-start to avoid false
  # positives when commit bodies mention the string as documentation/code).
  if git -C "$ROOT_DIR" log --format=%B "$policy_base..$local_sha" \
      | grep -qE '^Co-Authored-By:'; then
    printf '[ERROR] Commit contains Co-Authored-By footer.\n'
    printf '[ERROR] Direct commits must not have Co-Authored-By footers.\n'
    printf '[ERROR] This footer is only for builder agent commits.\n'
    printf '[ERROR] Amend the offending commit to remove the trailer.\n'
    exit 1
  fi

  # Validate conventional commits (scope allowlist, format, body) via alint.
  # The authoritative scope list lives in .alint.yml — no duplication here.
  if command -v alint &>/dev/null; then
    if ! ALINT_BASE_SHA="$policy_base" alint check --base "$policy_base" \
        "$ROOT_DIR" 2>&1; then
      printf '[ERROR] alint check failed.\n' >&2
      exit 1
    fi
  fi

  # Bean hygiene: run the same check CI runs (unarchived terminals, stale beans).
  # Soft-stale matches are advisory by default; hard hygiene findings still fail.
  BEAN_WRAPPER="$ROOT_DIR/.claude/skills/beans/bin/citum-bean"
  if [[ -x "$BEAN_WRAPPER" ]]; then
    printf '[PRE-PUSH] Running bean hygiene check...\n'
    if ! IGNORE_SOFT_STALE="${IGNORE_SOFT_STALE:-1}" "$BEAN_WRAPPER" hygiene; then
      printf '[ERROR] Bean hygiene failed. Fix before pushing.\n' >&2
      exit 1
    fi
  fi

  # Collect changed Rust files and Cargo manifests
  declare -a changed_rs_or_cargo=()
  while IFS= read -r path; do
    if [[ "$path" =~ \.(rs)$ ]] || [[ "$path" == "Cargo.toml" ]] || [[ "$path" == "Cargo.lock" ]]; then
      changed_rs_or_cargo+=("$path")
    fi
  done < <(git -C "$ROOT_DIR" diff --name-only --diff-filter=ACMR "$policy_base" "$local_sha")

  # If Rust files changed, run the gate
  if (( ${#changed_rs_or_cargo[@]} > 0 )); then
    printf '[PRE-PUSH] Rust files changed. Running gate checks...\n'
    printf '[PRE-PUSH] Running: cargo fmt --check\n'
    if ! cargo fmt --check --all 2>&1 | grep -q "Checking"; then
      :
    fi
    cargo fmt --check --all || {
      printf '[ERROR] Code formatting check failed.\n'
      printf '[ERROR] Run: cargo fmt --all\n'
      exit 1
    }

    printf '[PRE-PUSH] Running: cargo clippy --all-targets --all-features\n'
    cargo clippy --workspace --all-targets --exclude citum-pdf -- -D warnings || {
      printf '[ERROR] Clippy checks failed.\n'
      exit 1
    }

    printf '[PRE-PUSH] Running: cargo nextest run\n'
    cargo nextest run || {
      printf '[ERROR] Tests failed.\n'
      exit 1
    }
    printf '[PRE-PUSH] All Rust checks passed.\n'
  else
    printf '[INFO] No Rust files changed. Skipping cargo gate.\n'
  fi

done
