{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Array_of_Citation",
  "type": "array",
  "items": {
    "$ref": "#/definitions/Citation"
  },
  "definitions": {
    "Citation": {
      "description": "A citation containing one or more references.",
      "type": "object",
      "required": [
        "items"
      ],
      "properties": {
        "id": {
          "description": "The citation ID (optional, for tracking).",
          "type": [
            "string",
            "null"
          ]
        },
        "items": {
          "description": "The citation items (references being cited).",
          "type": "array",
          "items": {
            "$ref": "#/definitions/CitationItem"
          }
        },
        "mode": {
          "description": "Citation mode: integral (narrative) vs non-integral (parenthetical). Only relevant for author-date styles.",
          "allOf": [
            {
              "$ref": "#/definitions/CitationMode"
            }
          ]
        },
        "note-number": {
          "description": "Note number for footnote/endnote styles. Assigned by the document processor, not the citation processor.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0.0
        },
        "position": {
          "description": "Position of this citation in the document flow. Detected automatically by the processor or set explicitly by the caller.",
          "anyOf": [
            {
              "$ref": "#/definitions/Position"
            },
            {
              "type": "null"
            }
          ]
        },
        "prefix": {
          "description": "Prefix text before all citation items.",
          "type": [
            "string",
            "null"
          ]
        },
        "suffix": {
          "description": "Suffix text after all citation items.",
          "type": [
            "string",
            "null"
          ]
        },
        "suppress-author": {
          "description": "Suppress the author name across all items in this citation. Used when the author is already named in the prose: \"Smith argues (2020)\". Applies uniformly to all items — per-item suppression is not supported because mixed-visibility citations are typographically incoherent.",
          "type": "boolean"
        }
      }
    },
    "CitationItem": {
      "description": "A single citation item referencing a bibliography entry.",
      "type": "object",
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "description": "The reference ID (citekey).",
          "type": "string"
        },
        "locator": {
          "description": "Canonical locator value for pinpoint citations.",
          "anyOf": [
            {
              "$ref": "#/definitions/CitationLocator"
            },
            {
              "type": "null"
            }
          ]
        },
        "prefix": {
          "description": "Prefix text before this item",
          "type": [
            "string",
            "null"
          ]
        },
        "suffix": {
          "description": "Suffix text after this item",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "CitationLocator": {
      "oneOf": [
        {
          "$ref": "#/definitions/LocatorSegment"
        },
        {
          "type": "object",
          "required": [
            "segments"
          ],
          "properties": {
            "segments": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/LocatorSegment"
              }
            }
          }
        }
      ]
    },
    "CitationMode": {
      "description": "Citation mode for author-date styles.\n\nDetermines how the author name is rendered relative to the citation.",
      "oneOf": [
        {
          "description": "Author inline in text: \"Smith (2020) argues...\" Also known as \"narrative\" or \"in-text\" citations.",
          "type": "string",
          "enum": [
            "integral"
          ]
        },
        {
          "description": "Author in parentheses: \"(Smith, 2020)\" The default mode for most citations.",
          "type": "string",
          "enum": [
            "non-integral"
          ]
        }
      ]
    },
    "LocatorSegment": {
      "description": "A single segment of a compound locator.\n\nPairs a locator type with its value, e.g. `{ label: chapter, value: \"3\" }`.",
      "type": "object",
      "required": [
        "label",
        "value"
      ],
      "properties": {
        "label": {
          "description": "The locator type for this segment.",
          "allOf": [
            {
              "$ref": "#/definitions/LocatorType"
            }
          ]
        },
        "value": {
          "description": "The locator value (e.g., \"3\", \"42-45\").",
          "allOf": [
            {
              "$ref": "#/definitions/LocatorValue"
            }
          ]
        }
      }
    },
    "LocatorType": {
      "description": "Locator types for pinpoint citations.",
      "oneOf": [
        {
          "description": "Locator refers to a book within a larger work.",
          "type": "string",
          "enum": [
            "book"
          ]
        },
        {
          "description": "Locator refers to a chapter.",
          "type": "string",
          "enum": [
            "chapter"
          ]
        },
        {
          "description": "Locator refers to a clause.",
          "type": "string",
          "enum": [
            "clause"
          ]
        },
        {
          "description": "Locator refers to a column.",
          "type": "string",
          "enum": [
            "column"
          ]
        },
        {
          "description": "Locator refers to a corollary.",
          "type": "string",
          "enum": [
            "corollary"
          ]
        },
        {
          "description": "Locator refers to a definition.",
          "type": "string",
          "enum": [
            "definition"
          ]
        },
        {
          "description": "Locator refers to a division.",
          "type": "string",
          "enum": [
            "division"
          ]
        },
        {
          "description": "Locator refers to a figure.",
          "type": "string",
          "enum": [
            "figure"
          ]
        },
        {
          "description": "Locator refers to a folio.",
          "type": "string",
          "enum": [
            "folio"
          ]
        },
        {
          "description": "Locator refers to a numbered line.",
          "type": "string",
          "enum": [
            "line"
          ]
        },
        {
          "description": "Locator refers to a lemma.",
          "type": "string",
          "enum": [
            "lemma"
          ]
        },
        {
          "description": "Locator refers to a note.",
          "type": "string",
          "enum": [
            "note"
          ]
        },
        {
          "description": "Locator refers to a numbered unit.",
          "type": "string",
          "enum": [
            "number"
          ]
        },
        {
          "description": "Locator refers to an opus number.",
          "type": "string",
          "enum": [
            "opus"
          ]
        },
        {
          "description": "Locator refers to a page.",
          "type": "string",
          "enum": [
            "page"
          ]
        },
        {
          "description": "Locator refers to a paragraph.",
          "type": "string",
          "enum": [
            "paragraph"
          ]
        },
        {
          "description": "Locator refers to a sub-paragraph.",
          "type": "string",
          "enum": [
            "subparagraph"
          ]
        },
        {
          "description": "Locator refers to a sub-clause.",
          "type": "string",
          "enum": [
            "subclause"
          ]
        },
        {
          "description": "Locator refers to a sub-division.",
          "type": "string",
          "enum": [
            "subdivision"
          ]
        },
        {
          "description": "Locator refers to a sub-section.",
          "type": "string",
          "enum": [
            "subsection"
          ]
        },
        {
          "description": "Locator refers to a part or division.",
          "type": "string",
          "enum": [
            "part"
          ]
        },
        {
          "description": "Locator refers to a problem.",
          "type": "string",
          "enum": [
            "problem"
          ]
        },
        {
          "description": "Locator refers to a proposition.",
          "type": "string",
          "enum": [
            "proposition"
          ]
        },
        {
          "description": "Locator refers to a recital.",
          "type": "string",
          "enum": [
            "recital"
          ]
        },
        {
          "description": "Locator refers to a schedule.",
          "type": "string",
          "enum": [
            "schedule"
          ]
        },
        {
          "description": "Locator refers to a section.",
          "type": "string",
          "enum": [
            "section"
          ]
        },
        {
          "description": "Locator refers to a surah.",
          "type": "string",
          "enum": [
            "surah"
          ]
        },
        {
          "description": "Locator refers to a theorem.",
          "type": "string",
          "enum": [
            "theorem"
          ]
        },
        {
          "description": "Locator refers to an entry under a headword.",
          "type": "string",
          "enum": [
            "sub-verbo"
          ]
        },
        {
          "description": "Locator refers to a supplement.",
          "type": "string",
          "enum": [
            "supplement"
          ]
        },
        {
          "description": "Locator refers to a verse.",
          "type": "string",
          "enum": [
            "verse"
          ]
        },
        {
          "description": "Locator refers to a volume.",
          "type": "string",
          "enum": [
            "volume"
          ]
        },
        {
          "description": "Locator refers to a periodical volume.",
          "type": "string",
          "enum": [
            "volume-periodical"
          ]
        },
        {
          "description": "Locator refers to a monograph volume.",
          "type": "string",
          "enum": [
            "volume-book"
          ]
        },
        {
          "description": "Locator refers to an issue.",
          "type": "string",
          "enum": [
            "issue"
          ]
        },
        {
          "description": "Locator refers to an algorithm.",
          "type": "string",
          "enum": [
            "algorithm"
          ]
        }
      ]
    },
    "LocatorValue": {
      "description": "A locator value that supports both plain strings and explicit plurality.\n\nPlain strings use heuristic plural detection (checking for `-`, `–`, `,`, `&`). Use the explicit form to override when the heuristic fails (e.g., \"figure A-3\" should be singular despite containing a hyphen).",
      "anyOf": [
        {
          "description": "Plain string value with heuristic plural detection.",
          "type": "string"
        },
        {
          "description": "Explicit value with manual plural override.",
          "type": "object",
          "required": [
            "plural",
            "value"
          ],
          "properties": {
            "plural": {
              "description": "Whether this locator is plural.",
              "type": "boolean"
            },
            "value": {
              "description": "The locator value string.",
              "type": "string"
            }
          }
        }
      ]
    },
    "Position": {
      "description": "Position of a citation in the document flow.\n\nIndicates where this citation appears relative to previous citations of the same item(s). Used for note-based styles to detect ibid and subsequent citations, and for author-date styles to apply position-specific formatting rules (e.g., short forms after first citation).",
      "oneOf": [
        {
          "description": "First citation of an item.",
          "type": "string",
          "enum": [
            "first"
          ]
        },
        {
          "description": "Subsequent citation of an item (non-consecutive).",
          "type": "string",
          "enum": [
            "subsequent"
          ]
        },
        {
          "description": "Same item cited immediately before, no locator on either.",
          "type": "string",
          "enum": [
            "ibid"
          ]
        },
        {
          "description": "Same item cited immediately before, with different locator.",
          "type": "string",
          "enum": [
            "ibid-with-locator"
          ]
        }
      ]
    }
  }
}