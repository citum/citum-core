#!/usr/bin/env bash
# Beans skill wrapper for Citum.
# Adds project-level helpers on top of the upstream `beans` CLI.

set -euo pipefail

BEANS_BIN="beans"
BEANS_PATH=".beans"
BEAN_CACHE_VERSION="v1"

require_command() {
    local cmd=$1
    local message=$2

    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "Error: $message" >&2
        exit 1
    fi
}

ensure_beans_ready() {
    require_command "$BEANS_BIN" "beans CLI not found. Install via: brew install beans"

    if [[ ! -d "$BEANS_PATH" ]]; then
        echo "Error: No .beans directory found. Run 'beans init' first." >&2
        exit 1
    fi
}

require_jq() {
    require_command "jq" "jq is required for '/beans $CMD'."
}

beans_graphql_json() {
    "$BEANS_BIN" graphql --json "$1"
}

all_beans_json() {
    "$BEANS_BIN" list --json
}

progress() {
    if [[ "${BEAN_PROGRESS:-0}" == "1" ]]; then
        printf '%s\n' "$*" >&2
    fi
}

bean_cache_dir() {
    local git_dir

    git_dir=$(git rev-parse --git-dir 2>/dev/null || true)
    if [[ -z "$git_dir" ]]; then
        return 1
    fi

    printf '%s/beans-cache\n' "$git_dir"
}

bean_cache_key() {
    local since=${1:-}
    local main_sha

    main_sha=$(git rev-parse main 2>/dev/null || true)
    printf '%s|%s|%s' "$BEAN_CACHE_VERSION" "$main_sha" "$since" \
        | shasum -a 256 \
        | awk '{print $1}'
}

main_commit_evidence_json() {
    local since=${1:-}
    local cache_dir=""
    local cache_key=""
    local cache_file=""
    local cache_tmp=""
    local first=1
    local token
    local current_header=""
    local -a current_files=()

    if ! command -v git >/dev/null 2>&1; then
        echo "[]"
        return 0
    fi

    if ! git rev-parse --verify main >/dev/null 2>&1; then
        echo "[]"
        return 0
    fi

    cache_dir=$(bean_cache_dir || true)
    if [[ -n "$cache_dir" ]]; then
        mkdir -p "$cache_dir"
        cache_key=$(bean_cache_key "$since")
        cache_file="$cache_dir/main-commit-evidence-$cache_key.json"
        if [[ -f "$cache_file" ]]; then
            progress "  reusing cached main commit evidence"
            cat "$cache_file"
            return 0
        fi
    fi

    if [[ -n "$since" ]]; then
        progress "  scanning main commit history since $since"
    else
        progress "  scanning main commit history"
    fi

    emit_record() {
        local sha
        local date
        local subject
        local body
        local _
        local files_json

        IFS=$'\x1f' read -r sha date subject body _ <<< "$current_header"
        files_json=$(printf '%s\n' "${current_files[@]}" | jq -Rsc 'split("\n") | map(select(length > 0))')

        if [[ "$first" -eq 0 ]]; then
            printf ','
        fi
        first=0

        jq -cn \
            --arg sha "$sha" \
            --arg date "$date" \
            --arg subject "$subject" \
            --arg body "$body" \
            --argjson files "$files_json" \
            '{sha: $sha, date: $date, subject: $subject, body: $body, files: $files}'
    }

    if [[ -n "$cache_file" ]]; then
        cache_tmp="$cache_file.$$"
        {
            printf '['
            while IFS= read -r -d '' token; do
                if [[ "$token" == *$'\x1f'* ]]; then
                    if [[ -n "$current_header" ]]; then
                        emit_record
                    fi
                    current_header="$token"
                    current_files=()
                elif [[ -n "$current_header" ]]; then
                    current_files+=("$token")
                fi
            done < <(
                if [[ -n "$since" ]]; then
                    git log main --since="$since" -z --format='%H%x1f%cI%x1f%s%x1f%b%x1f' --name-only
                else
                    git log main -z --format='%H%x1f%cI%x1f%s%x1f%b%x1f' --name-only
                fi
            )

            if [[ -n "$current_header" ]]; then
                emit_record
            fi
            printf ']'
        } | tee "$cache_tmp"
        mv "$cache_tmp" "$cache_file"
    else
        printf '['
        while IFS= read -r -d '' token; do
            if [[ "$token" == *$'\x1f'* ]]; then
                if [[ -n "$current_header" ]]; then
                    emit_record
                fi
                current_header="$token"
                current_files=()
            elif [[ -n "$current_header" ]]; then
                current_files+=("$token")
            fi
        done < <(
            if [[ -n "$since" ]]; then
                git log main --since="$since" -z --format='%H%x1f%cI%x1f%s%x1f%b%x1f' --name-only
            else
                git log main -z --format='%H%x1f%cI%x1f%s%x1f%b%x1f' --name-only
            fi
        )

        if [[ -n "$current_header" ]]; then
            emit_record
        fi
        printf ']'
    fi
}

build_audit_json() {
    local scope=$1
    local all_json
    local main_commits_json
    local stale_since

    progress "  loading bean metadata"
    all_json=$(all_beans_json)
    stale_since=$(printf '%s\n' "$all_json" | jq -r '
        [
            .[]
            | select(.status == "draft" or .status == "todo" or .status == "in-progress")
            | (.updated_at // .created_at // empty)
            | select(length > 0)
        ]
        | sort
        | .[0] // ""
    ')
    progress "  deriving stale-bean evidence"
    main_commits_json=$(main_commit_evidence_json "$stale_since")
    progress "  matching open beans against landed work"

    local _tmpall _tmpcommits
    _tmpall=$(mktemp)
    _tmpcommits=$(mktemp)
    printf '%s' "$all_json" > "$_tmpall"
    printf '%s' "$main_commits_json" > "$_tmpcommits"

    jq -n \
        --arg scope "$scope" \
        --slurpfile all "$_tmpall" \
        --slurpfile main_commits "$_tmpcommits" '
        def norm_title:
            (. // ""
            | ascii_downcase
            | gsub("[[:space:]]+"; " ")
            | sub("^ "; "")
            | sub(" $"; ""));
        def short_sha: (. // "")[0:7];
        def is_archived: (.path // "" | startswith("archive/"));
        def is_terminal: (.status == "completed" or .status == "scrapped");
        def is_open: (.status == "draft" or .status == "todo" or .status == "in-progress");
        def is_canonical_status:
            (.status == "draft"
            or .status == "todo"
            or .status == "in-progress"
            or .status == "completed"
            or .status == "scrapped");
        def duplicate_groups:
            group_by(.title_norm)
            | map(
                select((.[0].title_norm | length) > 0 and length > 1)
                | {
                    normalized_title: .[0].title_norm,
                    titles: ([.[].title] | unique),
                    items: map({
                        id,
                        title,
                        status,
                        type,
                        priority,
                        path
                    })
                }
            );
        ($main_commits[0]
            | map(
                . + {
                    subject_norm: (.subject | norm_title),
                    subject_text: ((.subject // "") | ascii_downcase),
                    body_text: ((.body // "") | ascii_downcase),
                    touches_non_beans: (
                        (.files // [])
                        | any(. != "" and (startswith(".beans/") | not))
                    )
                }
            )) as $commits |
        ($all[0] | map(. + {title_norm: (.title | norm_title)})) as $items |
        (if $scope == "open"
            then [$items[] | select(is_archived | not)]
            else $items
         end) as $scoped |
        ([ $items[] | select(is_terminal) ]
            | group_by(.title_norm)
            | map({
                key: .[0].title_norm,
                value: map({
                    id,
                    title,
                    status,
                    type,
                    priority,
                    path
                })
            })
            | from_entries) as $terminal_by_title |
        {
            scope: $scope,
            noncanonical_statuses: [
                $scoped[]
                | select(is_canonical_status | not)
                | { id, title, status, path }
            ],
            root_terminal_beans: [
                $items[]
                | select((is_archived | not) and is_terminal)
                | { id, title, status, path }
            ],
            duplicate_titles: ($scoped | duplicate_groups),
            open_title_collisions: [
                $items[]
                | select((is_archived | not) and is_open)
                | select(.title_norm != "" and ($terminal_by_title[.title_norm] != null))
                | {
                    normalized_title: .title_norm,
                    open: {
                        id,
                        title,
                        status,
                        type,
                        priority,
                        path
                    },
                    terminal: $terminal_by_title[.title_norm]
                }
            ],
            duplicate_in_progress_migrate: (
                [
                    $items[]
                    | select(
                        (is_archived | not)
                        and .status == "in-progress"
                        and (.title | startswith("Migrate: "))
                    )
                ]
                | group_by(.title_norm)
                | map(
                    select(length > 1)
                    | {
                        normalized_title: .[0].title_norm,
                        title: .[0].title,
                        items: map({ id, status, path })
                    }
                )
            ),
            stale_open_beans_hard: [
                $items[]
                | select((is_archived | not) and is_open)
                | . as $bean
                | [
                    $commits[]
                    | select(.touches_non_beans)
                    | select(.subject_text | contains(($bean.id // "") | ascii_downcase))
                    | {
                        sha,
                        date,
                        subject,
                        match_type: "bean-id-subject"
                    }
                ] as $matches
                | select(($matches | length) > 0)
                | {
                    bean: {
                        id: $bean.id,
                        title: $bean.title,
                        status: $bean.status,
                        type: $bean.type,
                        priority: $bean.priority,
                        path: $bean.path
                    },
                    evidence: $matches
                }
            ],
            stale_open_umbrella_beans_hard: [
                $items[]
                | select(
                    (is_archived | not)
                    and is_open
                    and (.type == "epic" or .type == "milestone")
                )
                | . as $bean
                | [
                    $items[]
                    | select(
                        .id != $bean.id
                        and (
                            (.parent // "") == $bean.id
                            or (((.blocking // []) | index($bean.id)) != null)
                        )
                    )
                    | {
                        id,
                        title,
                        status,
                        type,
                        priority,
                        path
                    }
                ] as $linked
                | select(
                    ($linked | length) > 0
                    and ($linked | all(.status == "completed" or .status == "scrapped"))
                )
                | {
                    bean: {
                        id: $bean.id,
                        title: $bean.title,
                        status: $bean.status,
                        type: $bean.type,
                        priority: $bean.priority,
                        path: $bean.path
                    },
                    linked_terminal_beans: $linked
                }
            ],
            stale_open_beans_soft: [
                $items[]
                | select((is_archived | not) and is_open)
                | . as $bean
                | [
                    $commits[]
                    | select(.touches_non_beans)
                    | select(.subject_text | contains(($bean.id // "") | ascii_downcase))
                ] as $hard_id_matches
                | [
                    $commits[]
                    | select(.touches_non_beans)
                    | select(
                        (.subject_text | contains(($bean.id // "") | ascii_downcase) | not)
                        and (.body_text | contains(($bean.id // "") | ascii_downcase))
                    )
                    | {
                        sha,
                        date,
                        subject,
                        match_type: "bean-id-body"
                    }
                ] as $body_id_matches
                | [
                    $commits[]
                    | select(.subject_norm == $bean.title_norm)
                    | {
                        sha,
                        date,
                        subject,
                        match_type: "normalized-title"
                    }
                ] as $title_matches
                | select(
                    ($hard_id_matches | length) == 0
                    and (($body_id_matches | length) > 0 or ($title_matches | length) > 0)
                )
                | {
                    bean: {
                        id: $bean.id,
                        title: $bean.title,
                        status: $bean.status,
                        type: $bean.type,
                        priority: $bean.priority,
                        path: $bean.path
                    },
                    strength: (
                        if ($body_id_matches | length) > 0
                        then "body-id-match"
                        elif ($title_matches | length) == 1
                        then "unique-title-match"
                        else "ambiguous-title-match"
                        end
                    ),
                    evidence: ($body_id_matches + $title_matches)
                }
            ]
        }
    '
    local _jq_exit=$?
    rm -f "$_tmpall" "$_tmpcommits"
    return $_jq_exit
}

audit_has_findings() {
    jq -e '
        (.noncanonical_statuses | length) > 0
        or (.root_terminal_beans | length) > 0
        or (.duplicate_titles | length) > 0
        or (.open_title_collisions | length) > 0
        or (.duplicate_in_progress_migrate | length) > 0
        or (.stale_open_beans_hard | length) > 0
        or (.stale_open_umbrella_beans_hard | length) > 0
    ' >/dev/null
}

print_audit_text() {
    jq -r '
        def render_items(items):
            items
            | map("  - \(.id) [\(.status)] \(.title) (\(.path))")
            | join("\n");
        def render_commit_evidence(evidence):
            evidence
            | map("    evidence: \(.match_type) \(.sha[0:7]) \(.date) \(.subject)")
            | join("\n");
        def render_duplicate_groups(groups):
            groups
            | map(
                "- \(.titles | join(" / "))\n"
                + (
                    .items
                    | map("    \(.id) [\(.status)] (\(.path))")
                    | join("\n")
                )
            )
            | join("\n");
        def render_collision_groups(groups):
            groups
            | map(
                "- \(.open.id) [\(.open.status)] \(.open.title) (\(.open.path))\n"
                + (
                    .terminal
                    | map("    terminal: \(.id) [\(.status)] (\(.path))")
                    | join("\n")
                )
            )
            | join("\n");
        def render_migrate_groups(groups):
            groups
            | map(
                "- \(.title)\n"
                + (
                    .items
                    | map("    \(.id) [\(.status)] (\(.path))")
                    | join("\n")
                )
            )
            | join("\n");
        def render_stale_groups(groups):
            groups
            | map(
                "- \(.bean.id) [\(.bean.status)] \(.bean.title) (\(.bean.path))\n"
                + render_commit_evidence(.evidence)
            )
            | join("\n");
        def render_terminal_linked_groups(groups):
            groups
            | map(
                "- \(.bean.id) [\(.bean.status)] \(.bean.title) (\(.bean.path))\n"
                + (
                    .linked_terminal_beans
                    | map("    linked-terminal: \(.id) [\(.status)] (\(.path))")
                    | join("\n")
                )
            )
            | join("\n");
        def render_soft_stale_groups(groups):
            groups
            | map(
                "- \(.bean.id) [\(.bean.status)] \(.bean.title) (\(.bean.path)) [\(.strength)]\n"
                + render_commit_evidence(.evidence)
            )
            | join("\n");
        if (
            (.noncanonical_statuses | length) == 0
            and (.root_terminal_beans | length) == 0
            and (.duplicate_titles | length) == 0
            and (.open_title_collisions | length) == 0
            and (.duplicate_in_progress_migrate | length) == 0
            and (.stale_open_beans_hard | length) == 0
            and (.stale_open_umbrella_beans_hard | length) == 0
            and (.stale_open_beans_soft | length) == 0
        ) then
            "No bean hygiene issues found."
        else
            (
                ["Bean audit scope: \(.scope)"] +
                (if (.noncanonical_statuses | length) > 0 then
                    ["", "Noncanonical statuses:", render_items(.noncanonical_statuses)]
                 else [] end) +
                (if (.root_terminal_beans | length) > 0 then
                    ["", "Root-level terminal beans that should be archived:", render_items(.root_terminal_beans)]
                 else [] end) +
                (if (.duplicate_titles | length) > 0 then
                    ["", "Duplicate normalized titles:", render_duplicate_groups(.duplicate_titles)]
                 else [] end) +
                (if (.open_title_collisions | length) > 0 then
                    ["", "Open beans colliding with completed/scrapped titles:", render_collision_groups(.open_title_collisions)]
                 else [] end) +
                (if (.duplicate_in_progress_migrate | length) > 0 then
                    ["", "Duplicate in-progress migrate beans:", render_migrate_groups(.duplicate_in_progress_migrate)]
                 else [] end) +
                (if (.stale_open_beans_hard | length) > 0 then
                    ["", "Open beans with landed work on main (hard failure):", render_stale_groups(.stale_open_beans_hard)]
                 else [] end) +
                (if (.stale_open_umbrella_beans_hard | length) > 0 then
                    ["", "Open umbrella beans whose linked child work is all terminal (hard failure):", render_terminal_linked_groups(.stale_open_umbrella_beans_hard)]
                 else [] end) +
                (if (.stale_open_beans_soft | length) > 0 then
                    ["", "Open beans with advisory title-only matches on main:", render_soft_stale_groups(.stale_open_beans_soft)]
                 else [] end)
            ) | join("\n")
        end
    '
}

run_next() {
    local limit=3
    local json_output=0
    local all_rel_json
    local meta_json
    local all_json
    local ready_json
    local in_progress_json
    local ready_count
    local open_ids_json
    local ranked_json
    local parent_ids
    local parent_map='{}'
    local candidates_json
    local first_id

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --limit|-n)
                limit="${2:-}"
                shift 2
                ;;
            --json)
                json_output=1
                shift
                ;;
            *)
                echo "Unknown option for next: $1" >&2
                exit 1
                ;;
        esac
    done

    if [[ ! "$limit" =~ ^[1-9][0-9]*$ ]]; then
        echo "Error: --limit must be a positive integer." >&2
        exit 1
    fi

    all_rel_json=$(beans_graphql_json '{
        beans(filter: {
            excludeStatus: ["completed", "scrapped", "draft"]
        }) {
            id title status type priority parentId blockingIds blockedByIds createdAt
        }
    }')
    meta_json=$(all_beans_json)

    all_json=$(jq -n \
        --argjson rel "$(printf "%s\n" "$all_rel_json" | jq '.beans')" \
        --argjson meta "$meta_json" '
        ($meta
            | map({ key: .id, value: (.created_at // "") })
            | from_entries) as $created_by_id |
        $rel
        | map(
            . + {
                created_at: (.createdAt // $created_by_id[.id] // "")
            }
        )
    ')

    in_progress_json=$(printf "%s\n" "$all_json" | jq '[.[] | select(.status == "in-progress")]')
    ready_json=$(printf "%s\n" "$all_json" | jq '
        [
            .[]
            | select(.status == "todo" and (.blockedByIds | length == 0))
        ]
    ')
    ready_count=$(printf "%s\n" "$ready_json" | jq 'length')

    if [[ "$ready_count" -eq 0 ]]; then
        if [[ "$json_output" -eq 1 ]]; then
            echo "[]"
        else
            echo "No ready beans found."
        fi
        return 0
    fi

    open_ids_json=$(printf "%s\n" "$all_json" | jq '[.[].id]')

    ranked_json=$(printf "%s\n" "$ready_json" | jq --argjson limit "$limit" --argjson open_ids "$open_ids_json" '
        ($open_ids | map({ key: ., value: true }) | from_entries) as $open |
        map(
            . + {
                leverage: ([.blockingIds[] | select($open[.] == true)] | length),
                priority: (.priority // "normal")
            }
        ) as $items |
        def priority_rank:
            if .priority == "critical" then 0
            elif .priority == "high" then 1
            elif .priority == "normal" then 2
            elif .priority == "low" then 3
            else 4 end;
        def type_rank:
            if .type == "bug" then 0
            elif .type == "feature" then 1
            elif .type == "task" then 2
            elif .type == "milestone" then 3
            elif .type == "epic" then 4
            else 5 end;
        (
            $items
            | map(select((.type // "") != "epic" and (.type // "") != "milestone"))
            | sort_by(priority_rank, (-.leverage), type_rank, .created_at, .title)
        ) as $concrete |
        (
            $items
            | map(select((.type // "") == "epic" or (.type // "") == "milestone"))
            | sort_by(priority_rank, (-.leverage), type_rank, .created_at, .title)
        ) as $meta |
        ($concrete + $meta)[:$limit]
    ')

    parent_ids=$(printf "%s\n" "$ranked_json" | jq -r '.[].parentId // empty' | sort -u | tr '\n' ' ')
    if [[ -n "${parent_ids// /}" ]]; then
        parent_map=$(beans show --json $parent_ids | jq '
            (if type == "array" then . else [.] end)
            | map({ key: .id, value: .title })
            | from_entries
        ')
    fi

    candidates_json=$(jq -n \
        --argjson items "$ranked_json" \
        --argjson parents "$parent_map" '
        $items
        | map(
            . + {
                parent_title: (
                    if (.parentId != null and ($parents[.parentId] != null))
                    then $parents[.parentId]
                    else null
                    end
                ),
                reason: (
                    ["priority=" + (.priority // "normal")] +
                    (if .leverage > 0 then ["unblocks=" + (.leverage | tostring)] else [] end) +
                    ["type=" + (.type // "task")]
                ) | join(", ")
            }
        )
    ')

    if [[ "$json_output" -eq 1 ]]; then
        printf "%s\n" "$candidates_json"
        return 0
    fi

    if [[ "$(printf "%s\n" "$in_progress_json" | jq 'length')" -gt 0 ]]; then
        echo "In progress:"
        printf "%s\n" "$in_progress_json" | jq -r '
            .[]
            | "  \(.id)  \(.type) · \(.priority // "normal")\n  \(.title)"
        '
        echo ""
    fi

    printf "%s\n" "$candidates_json" | jq -r '
        to_entries[]
        | (.value.leverage // 0) as $leverage
        | "#\(.key + 1)  \(.value.id)  \(.value.type) · \(.value.priority)" +
          (if $leverage > 0 then " · unblocks \($leverage)" else "" end) +
          "\n    \(.value.title)" +
          (if .value.parent_title then "\n    Parent: \(.value.parent_title)" else "" end)
    '

    first_id=$(printf "%s\n" "$candidates_json" | jq -r '.[0].id')
    echo ""
    echo "Recommendation: start with $first_id"
}

run_audit() {
    local scope="open"
    local json_output=0
    local audit_json

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --scope)
                scope="${2:-}"
                shift 2
                ;;
            --json)
                json_output=1
                shift
                ;;
            *)
                echo "Unknown option for audit: $1" >&2
                exit 1
                ;;
        esac
    done

    if [[ "$scope" != "open" && "$scope" != "all" ]]; then
        echo "Error: --scope must be 'open' or 'all'." >&2
        exit 1
    fi

    if [[ "$json_output" -eq 1 ]]; then
        audit_json=$(BEAN_PROGRESS=0 build_audit_json "$scope")
    else
        audit_json=$(BEAN_PROGRESS=1 build_audit_json "$scope")
    fi

    if [[ "$json_output" -eq 1 ]]; then
        printf "%s\n" "$audit_json"
    else
        printf "%s\n" "$audit_json" | print_audit_text
    fi
}

run_hygiene() {
    local scope="open"
    local json_output=0
    local audit_json

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --scope)
                scope="${2:-}"
                shift 2
                ;;
            --json)
                json_output=1
                shift
                ;;
            *)
                echo "Unknown option for hygiene: $1" >&2
                exit 1
                ;;
        esac
    done

    if [[ "$scope" != "open" && "$scope" != "all" ]]; then
        echo "Error: --scope must be 'open' or 'all'." >&2
        exit 1
    fi

    if [[ "$json_output" -eq 1 ]]; then
        audit_json=$(BEAN_PROGRESS=0 build_audit_json "$scope")
    else
        audit_json=$(BEAN_PROGRESS=1 build_audit_json "$scope")
    fi

    if [[ "$json_output" -eq 1 ]]; then
        printf "%s\n" "$audit_json"
    else
        printf "%s\n" "$audit_json" | print_audit_text
    fi

    if printf "%s\n" "$audit_json" | audit_has_findings; then
        exit 1
    fi
}

usage() {
    cat <<'EOF'
Beans Task Management - Citum

USAGE:
    /beans COMMAND [OPTIONS]

PROJECT COMMANDS:
    next [--limit N] [--json]
        Show top ready bean options ranked by priority, leverage, type, and age.

    audit [--scope open|all] [--json]
        Report bean lifecycle, stale-bean, and duplicate-title hygiene issues.

    hygiene [--scope open|all] [--json]
        Run the bean hygiene audit and exit nonzero on findings.

UPSTREAM COMMANDS:
    list ...
    show ...
    create ...
    update ...
    delete ...
    archive ...
    graphql ...
    prime
        Passed directly through to the `beans` CLI.

EXAMPLES:
    /beans next
    /beans next --limit 5
    /beans audit --scope open
    /beans hygiene
    /beans graphql --json '{ beans { id title status } }'
    /beans show csl26-abc1

For full CLI documentation, see: beans help
EOF
}

ensure_beans_ready

CMD="${1:-help}"
shift || true

case "$CMD" in
    next)
        require_jq
        run_next "$@"
        ;;
    audit)
        require_jq
        run_audit "$@"
        ;;
    hygiene)
        require_jq
        run_hygiene "$@"
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        "$BEANS_BIN" "$CMD" "$@"
        ;;
esac
