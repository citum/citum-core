#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 2 ]]; then
  cat <<'EOF' >&2
Usage:
  ./scripts/codex <role> <target...>

Roles:
  style-evolve
  migration-researcher
  style-qa-reviewer
  rust-implementer
  spec-planner
  docs-curator
EOF
  exit 2
fi

role="$1"
shift
target="$*"

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
agent_policy="$repo_root/docs/policies/AGENT_HARNESS_POLICY.md"
agent_guide="$repo_root/docs/guides/AGENT_ORCHESTRATION.md"
docs_policy="$repo_root/docs/policies/STYLE_WORKFLOW_DECISION_RULES.md"
docs_guide="$repo_root/docs/guides/STYLE_WORKFLOW_EXECUTION.md"
coding_standards="$repo_root/docs/guides/CODING_STANDARDS.md"

prompt_for_role() {
  case "$1" in
    style-evolve)
      cat <<EOF
Use the style-evolve role for: $target

Read:
- $agent_policy
- $agent_guide
- $docs_policy
- $docs_guide

Route the request to the right style mode and keep the response short.
EOF
      ;;
    migration-researcher)
      cat <<EOF
Use the migration-researcher role for: $target

Read:
- $agent_policy
- $agent_guide
- $docs_policy
- $docs_guide

Run one bounded migration cluster pass and report the classification.
EOF
      ;;
    style-qa-reviewer)
      cat <<EOF
Use the style-qa-reviewer role for: $target

Read:
- $agent_policy
- $agent_guide
- $docs_policy
- $docs_guide

Review only. Return approve or reject with concise findings.
EOF
      ;;
    rust-implementer)
      cat <<EOF
Use the rust-implementer role for: $target

Read:
- $agent_policy
- $agent_guide
- $coding_standards

Implement the smallest bounded Rust change and report verification.
EOF
      ;;
    spec-planner)
      cat <<EOF
Use the spec-planner role for: $target

Read:
- $agent_policy
- $agent_guide

Produce a decision-complete plan only.
EOF
      ;;
    docs-curator)
      cat <<EOF
Use the docs-curator role for: $target

Read:
- $agent_policy
- $agent_guide

Update docs and public Rust item comments only.
EOF
      ;;
    *)
      echo "Unknown role: $role" >&2
      exit 2
      ;;
  esac
}

model_for_role() {
  case "$1" in
    spec-planner|style-evolve)
      echo "${CITUM_CODEX_PLANNER_MODEL:-${CODEX_PLANNER_MODEL:-}}"
      ;;
    style-qa-reviewer)
      echo "${CITUM_CODEX_REVIEWER_MODEL:-${CODEX_REVIEWER_MODEL:-}}"
      ;;
    *)
      echo "${CITUM_CODEX_WORKER_MODEL:-${CODEX_WORKER_MODEL:-}}"
      ;;
  esac
}

effort_for_role() {
  case "$1" in
    spec-planner|style-evolve)
      echo "${CITUM_CODEX_PLANNER_REASONING_EFFORT:-${CODEX_PLANNER_REASONING_EFFORT:-}}"
      ;;
    style-qa-reviewer)
      echo "${CITUM_CODEX_REVIEWER_REASONING_EFFORT:-${CODEX_REVIEWER_REASONING_EFFORT:-}}"
      ;;
    *)
      echo "${CITUM_CODEX_WORKER_REASONING_EFFORT:-${CODEX_WORKER_REASONING_EFFORT:-}}"
      ;;
  esac
}

prompt="$(prompt_for_role "$role")"

if command -v codex >/dev/null 2>&1; then
  model="$(model_for_role "$role")"
  effort="$(effort_for_role "$role")"
  codex_args=(exec --cd "$repo_root")
  if [[ -n "$model" ]]; then
    codex_args+=(--model "$model")
  fi
  if [[ -n "$effort" ]]; then
    codex_args+=(-c "model_reasoning_effort=\"$effort\"")
  fi
  if codex "${codex_args[@]}" "$prompt"; then
    exit 0
  fi
fi

cat <<EOF >&2
Codex runtime unavailable or rejected the request.

Model and reasoning selection are user-configured. Set
CITUM_CODEX_PLANNER_MODEL, CITUM_CODEX_WORKER_MODEL, or
CITUM_CODEX_REVIEWER_MODEL to force a model for the corresponding role tier.
Set CITUM_CODEX_PLANNER_REASONING_EFFORT,
CITUM_CODEX_WORKER_REASONING_EFFORT, or
CITUM_CODEX_REVIEWER_REASONING_EFFORT to force Codex reasoning effort.

Prompt template for manual use:

$prompt
EOF
exit 127
